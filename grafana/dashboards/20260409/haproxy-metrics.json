{
  "uid": "haproxy-metrics",
  "title": "HAProxy Metrics",
  "tags": ["haproxy", "proxy"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "panels": [
    {"id": 1, "title": "Uptime", "type": "stat", "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0}, "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "targets": [{"expr": "haproxy_process_uptime_seconds", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "s"}}},
    {"id": 2, "title": "Current Sessions", "type": "stat", "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0}, "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "targets": [{"expr": "sum(haproxy_frontend_current_sessions)", "refId": "A"}]},
    {"id": 3, "title": "Request Rate", "type": "stat", "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0}, "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "targets": [{"expr": "sum(rate(haproxy_frontend_http_requests_total[5m]))", "refId": "A"}], "fieldConfig": {"defaults": {"unit": "reqps"}}},
    {"id": 4, "title": "Active Backends", "type": "stat", "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0}, "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "targets": [{"expr": "sum(haproxy_backend_active_servers)", "refId": "A"}]},
    {"id": 5, "title": "Request Rate by Frontend", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4}, "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "targets": [{"expr": "rate(haproxy_frontend_http_requests_total[5m])", "legendFormat": "{{proxy}}", "refId": "A"}]},
    {"id": 6, "title": "Sessions by Frontend", "type": "timeseries", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4}, "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"}, "targets": [{"expr": "haproxy_frontend_current_sessions", "legendFormat": "{{proxy}}", "refId": "A"}]}
  ]
}
